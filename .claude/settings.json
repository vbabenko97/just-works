{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(du:*)",
      "Bash(which:*)",
      "Bash(diff:*)",
      "Bash(pwd:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/.netrc)",
      "Read(**/.pgpass)",
      "Read(**/.aws/*)",
      "Read(**/.gcp/*)",
      "Read(**/service-account*.json)",
      "Read(**/.azure/*)",
      "Read(**/terraform.tfvars)",
      "Read(**/*.tfstate)",
      "Read(**/*.tfstate.*)",
      "Read(**/.ssh/*)",
      "Read(**/.gnupg/*)",
      "Read(**/*.sqlite)",
      "Read(**/*.db)",
      "Read(**/.htpasswd)",
      "Read(**/package-lock.json)",
      "Read(**/pnpm-lock.yaml)",
      "Read(**/yarn.lock)",
      "Read(**/Cargo.lock)",
      "Read(**/poetry.lock)",
      "Read(**/uv.lock)",
      "Read(**/node_modules/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/.next/**)",
      "Read(**/target/**)",
      "Read(**/coverage/**)",
      "Read(**/*.min.js)",
      "Read(**/*.map)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "cleanupPeriodDays": 180,
  "maxTerminalOutputChars": 200000,
  "maxFileReadTokens": 50000,
  "autoCompactPercentageOverride": 80,
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "plansDirectory": "./.claude/plans",
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus[1m]",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "BASH_MAX_OUTPUT_LENGTH": "200000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"$HOME/.claude/hooks/rtk-rewrite.sh\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
