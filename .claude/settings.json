{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(du:*)",
      "Bash(which:*)",
      "Bash(diff:*)",
      "Bash(pwd:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/.netrc)",
      "Read(**/.pgpass)",
      "Read(**/.aws/*)",
      "Read(**/.gcp/*)",
      "Read(**/service-account*.json)",
      "Read(**/.azure/*)",
      "Read(**/terraform.tfvars)",
      "Read(**/*.tfstate)",
      "Read(**/*.tfstate.*)",
      "Read(**/.ssh/*)",
      "Read(**/.gnupg/*)",
      "Read(**/*.sqlite)",
      "Read(**/*.db)",
      "Read(**/.htpasswd)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "includeCoAuthoredBy": false,
  "enableAllProjectMcpServers": true,
  "cleanupPeriodDays": 180,
  "maxTerminalOutputChars": 200000,
  "maxFileReadTokens": 50000,
  "autoCompactPercentageOverride": 80,
  "autoMemoryEnabled": false,
  "plansDirectory": "./.claude/plans",
  "outputStyle": "default",
  "spinnerTipsEnabled": true,
  "effortLevel": "high",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_SUBAGENT_MODEL": "opus[1m]",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "BASH_MAX_OUTPUT_LENGTH": "200000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo '$CLAUDE_TOOL_INPUT' | jq -r '.file_path') && [ -f \"$FILE\" ] && LINES=$(wc -l < \"$FILE\") && [ \"$LINES\" -gt 500 ] && echo 'File is too large, do not read it fully. Use offset and limit parameters to read specific sections.' >&2 && exit 2 || exit 0"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
